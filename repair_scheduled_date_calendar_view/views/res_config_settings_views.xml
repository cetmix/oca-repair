<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record
        id="res_config_settings_view_form_inherit_repair_calendar"
        model="ir.ui.view"
    >
        <field name="name">res.config.settings.repair.calendar</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="repair" string="Repairs">
                    <block title="Planning">
                        <setting
                            string="Default Planned Order Duration"
                            help="Default planned duration for repair orders."
                        >
                            <field
                                name="planned_duration_default"
                                widget="float_time"
                            />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
