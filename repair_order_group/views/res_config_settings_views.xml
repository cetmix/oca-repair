<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record
        id="res_config_settings_view_form_inherit_repair_order_group"
        model="ir.ui.view"
    >
        <field name="name">res.config.settings.repair.order.group</field>
        <field name="model">res.config.settings</field>
        <field
            name="inherit_id"
            ref="base_repair_config.res_config_settings_view_form"
        />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='repair_setting_container']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <i class="fa fa-wrench" />
                    </div>
                    <div class="o_setting_right_pane">
                        <span
                            class="o_form_label"
                        >'Add Grouped Repair' available in states</span>
                        <div class="text-muted">
                            States in which the "Add Grouped Repair" button is shown
                            on the Repair Order form. Always hidden when the related
                            sale order is confirmed or cancelled.
                            If no states are selected the button is hidden everywhere.
                        </div>
                        <div class="mt16">
                            <field name="grouped_repair_state_draft" />
                            <label
                                for="grouped_repair_state_draft"
                                class="o_form_label"
                            />
                        </div>
                        <div>
                            <field name="grouped_repair_state_confirmed" />
                            <label
                                for="grouped_repair_state_confirmed"
                                class="o_form_label"
                            />
                        </div>
                        <div>
                            <field name="grouped_repair_state_under_repair" />
                            <label
                                for="grouped_repair_state_under_repair"
                                class="o_form_label"
                            />
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
