<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_order_form_inherit_sequence" model="ir.ui.view">
        <field name="name">repair.order.form.sequence</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.repair_order_form_view"/>
        <field name="arch" type="xml">
            <!-- Make parts lines editable in place and sort by sequence -->
            <xpath expr="//notebook/page[@name='parts']/field[@name='operations']/tree" position="attributes">
                <attribute name="editable">bottom</attribute>
                <attribute name="default_order">sequence asc</attribute>
            </xpath>
            <!-- Add handle column to allow drag & drop reordering -->
            <xpath expr="//notebook/page[@name='parts']/field[@name='operations']/tree" position="inside">
                <field name="sequence" widget="handle"/>
            </xpath>
        </field>
    </record>
</odoo>